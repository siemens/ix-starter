{
  "include": [
    "tsdown.config.ts",
    "src",
    "__tests__"
  ],
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "target": "es2023",
    "module": "preserve",
    "types": [
      "node"
    ],
    "noEmit": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noUnusedLocals": true
  }
}