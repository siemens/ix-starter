{
  "name": "element-starter",
  "description": "Element starter project",
  "version": "0.0.1",
  "license": "SEE LICENSE IN LICENSE.md",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:prod": "http-server dist/element-starter/browser -s -p 4200 -a 127.0.0.1",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch",
    "test": "ng test",
    "lint": "ng lint",
    "lint:sass": "stylelint **.scss",
    "lint:all": "npm run lint && npm run lint:sass",
    "e2e:prepare": "playwright install",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint:format": "echo no formatter; exit 0"
  },
  "dependencies": {
    "@angular/cdk": "22.0.5",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/router": "22.0.6",
    "@ngx-translate/core": "17.0.0",
    "@ngx-translate/http-loader": "17.0.0",
    "@siemens/element-ng": "49.13.0",
    "@siemens/element-icons": "1.2.0",
    "@simpl/brand": "3.3.0",
    "@siemens/element-translate-ng": "49.13.0",
    "@siemens/element-theme": "49.13.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "22.0.7",
    "@angular/cli": "22.0.7",
    "@angular/compiler-cli": "22.0.6",
    "@angular/language-service": "22.0.6",
    "@angular-eslint/builder": "22.1.0",
    "@playwright/test": "1.61.1",
    "@eslint/js": "10.0.1",
    "@siemens/eslint-config-angular": "4.4.2",
    "@siemens/stylelint-config-scss": "4.4.2",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "^4.1.9",
    "angular-eslint": "22.0.0",
    "eslint": "10.6.0",
    "eslint-plugin-perfectionist": "5.10.0",
    "eslint-plugin-prefer-arrow": "1.2.3",
    "http-server": "^14.0.0",
    "postcss": "^8.4.29",
    "postcss-scss": "4.0.9",
    "stylelint": "17.14.0",
    "stylelint-scss": "7.2.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "^4.1.9"
  }
}
