{
  "name": "ix-starter",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:create": "pnpm --filter create-siemens-web build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:create": "pnpm --filter create-siemens-web build && vitest run",
    "e2e": "turbo run e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "eslint": "^9.12.0",
    "execa": "9.6.1",
    "ix-theme-downloader": "workspace:*",
    "prettier": "^3.3.3",
    "turbo": "latest",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.17.0",
  "engines": {
    "pnpm": ">=10.x.x"
  },
  "volta": {
    "node": "22.21.0"
  }
}
